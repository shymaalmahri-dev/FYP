# Copy to /etc/elai/inference.env on Ubuntu and edit only if your paths differ.

PROJECT_HOME=/home/admin/FYP
INFERENCE_SCRIPT=/home/admin/FYP/inference.py
VENV_PYTHON=/home/admin/FYP/venv/bin/python

CAPTURE_INTERFACE=enp0s8
PROTECTED_VM_IP=192.168.56.101
PROTECTED_VM_CIDR=192.168.56.101/24
DASHBOARD_ALERT_URL=http://localhost:4000/api/alerts

# Lab-noise filters for the Kali -> Ubuntu demo path.
ELAI_MONITOR_DST_IP=192.168.56.101
ELAI_ALLOW_SRC_IPS=192.168.56.102
ELAI_NORMAL_MIN_PROBA=0.85
ELAI_ATTACK_STRONG_PROBA=0.90
ELAI_GRAY_MIN_PROBA=0.60
ELAI_GRAY_ZONE_ENABLED=1
ELAI_NORMAL_SAMPLE_RATE=0.20
ELAI_SOFT_NORMAL_MIN_PROBA=0.45
ELAI_SOFT_NORMAL_MAX_GAP=0.12
ELAI_ALERT_COOLDOWN_SEC=5

# Optional edge block agent settings. Keep the token in sync with the dashboard env.
EDGE_BLOCK_AGENT_HOST=0.0.0.0
EDGE_BLOCK_AGENT_PORT=8787
EDGE_BLOCK_AGENT_URL=http://127.0.0.1:8787/block-ip
EDGE_BLOCK_AGENT_TOKEN=change-me
