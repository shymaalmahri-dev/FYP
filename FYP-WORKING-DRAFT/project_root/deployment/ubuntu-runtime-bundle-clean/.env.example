# Root-level reference for the ELAI project

# Dashboard settings
DATABASE_URL=mysql://user:password@localhost:3306/elai
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=
VITE_APP_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
PORT=4000
NODE_ENV=development

# Deep analysis
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Optional JSON alert backfill for the dashboard
ENABLE_FILE_ALERT_INGESTION=false

# Optional explicit Python executable for dashboard-side Python calls
PYTHON_PATH=python
