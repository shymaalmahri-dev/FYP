NODE_ENV=development
PORT=4000

# Required for the dashboard database-backed runtime
DATABASE_URL=mysql://user:password@localhost:3306/elai

# Optional auth-related settings
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=
VITE_APP_ID=

# Optional internal AI / Forge settings
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Ollama-backed deep analysis
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# Leave disabled for normal direct-ingestion operation.
# Enable only when you want to backfill alerts from explainable_ai/*.json files.
ENABLE_FILE_ALERT_INGESTION=false

# Optional edge-device block enforcement
EDGE_BLOCK_AGENT_URL=
EDGE_BLOCK_AGENT_TOKEN=
